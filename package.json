{
  "name": "cloud-novels",
  "version": "0.1.0",
  "description": "小说文本转语音服务 — 基于 Fastify + Zod + 阿里云百炼 CosyVoice",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:api": "tsx scripts/gen-api-docs.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "openai": "^6.45.0",
    "ws": "^8.21.0",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
